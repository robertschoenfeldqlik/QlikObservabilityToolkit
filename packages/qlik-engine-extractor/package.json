  "type": "module",
  "bin": {
    "qlik-engine-extractor": "bin/qlik-engine-extractor.mjs"
  },
  "scripts": {
    "postinstall": "node bin/qlik-engine-extractor.mjs bootstrap --auto || true"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "talend",
    "qlik",
    "prometheus",
    "remote-engine",
    "observability",
    "headless-agent"
  ],
