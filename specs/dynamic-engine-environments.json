  "components": {
    "schemas": {
      "DEEnvironment": {
        "type": "object",
        "required": [
          "description",
          "id",
          "logStrategy",
          "metricsStrategy",
          "name",
          "status"
        ],
        "description": "While providing all capacity related to Environments (see description), Dynamic Engine Environment also brings Dynamic Engine processing for all tasks or plans defined within. \n\nThis **processing capacity** is provided through the assignment of your Environment to one (and one only) available Dynamic Engine. Doing so, you dont need to provide any Engine definition on the task level.  \n\nThis processing capacity is **exclusive**, meaning all tasks or plans defined in your Environment will target this Dynamic Engine for execution. \n\nThe **status** as defined here on Dynamic Engine Environment reflects both this assignment state and the **processing readiness state**. ",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier"
          },
          "name": {
            "type": "string",
            "description": "Unique name"
          },
          "description": {
            "type": "string",
            "description": "Description"
          },
          "deId": {
            "type": "string",
            "description": "Identifier of the Dynamic Engine this Environment might be connected to"
          },
          "status": {
            "type": "string",
            "description": "Status of your Dynamic Engine Environment. Possible statuses are the following :\n\n**Not Assigned** : Environment can be used for any Orchestration/configuration action : add workspace, etc.\n\n**Set Up Required** : Transitional state. Some DE link is configured but technical setup is still required in order for Processing to be available for your Environment. Please ask your Infra Admin. \n\n**Ready** : Ressources for your Environment have been installed successfully. Processing is fully available.\n\n**Not Ready** : Error state. DE link is configured but some error occured on Dynamic Engine. Please check with your Infra Admin.",
            "enum": [
              "NOT_ASSIGNED",
              "SET_UP_REQUIRED",
              "READY",
              "NOT_READY"
            ]
          },
          "logStrategy": {
            "type": "string",
            "description": "DynamicEngine Strategy on logs regarding this Environment's executions",
            "enum": [
              "NONE",
              "CONTROL_PLANE",
              "DYNAMIC_ENGINE"
            ]
          },
          "metricsStrategy": {
            "type": "string",
            "description": "DynamicEngine Strategy on metrics regarding this Environment's executions",
            "enum": [
              "NONE",
              "CONTROL_PLANE",
              "DYNAMIC_ENGINE"
            ]
          },
          "createdBy": {
            "type": "string",
            "description": "Username of user who created Dynamic Engine Environment",
            "example": "admin"
          },
          "creationDate": {
            "type": "string",
            "format": "date-time",
            "description": "Creation Date of Dynamic Engine Environment"
          },
          "lastModifiedBy": {
            "type": "string",
            "description": "Username of user who last updated Dynamic Engine Environment",
            "example": "admin"
          },
          "lastModifiedDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date of the last modification made by user"
          },
          "creatorType": {
            "type": "string",
            "description": "Type of user who created Dynamic Engine Environment, either HUMAN or SERVICE",
            "enum": [
              "HUMAN",
              "SERVICE"
            ],
            "example": "SERVICE"
          },
          "modifierType": {
            "type": "string",
            "description": "Type of user who last modified Dynamic Engine Environment, either HUMAN or SERVICE",
            "enum": [
              "HUMAN",
              "SERVICE"
            ],
            "example": "HUMAN"
          },
          "linkId": {
            "type": "string",
            "description": "Dynamic Engine Assignment link unique id. Unmutable data allowing to setup and cleanup resources on the Dynamic Engine for your Environment."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "integer",
            "description": "HTTP status code",
            "example": 401
          },
          "message": {
            "type": "string",
            "description": "Info about the error for user",
            "example": "Forbidden"
          },
          "detail": {
            "type": "string",
            "description": "Info about error for developer.",
            "example": "Token authorization is required for access"
          },
          "requestId": {
            "type": "string",
            "description": "The unique identification of the request involved with this error",
            "example": "16fefb53-035a-4249-af9d-f80a3b47b132"
          }
        }
      },
      "CreateDynamicEngineEnvironmentRequest": {
        "type": "object",
        "required": [
          "name",
          "workspaceName"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "workspaceName": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "logStrategy": {
            "type": "string",
            "description": "default value is NONE",
            "enum": [
              "NONE",
              "CONTROL_PLANE",
              "DYNAMIC_ENGINE"
            ]
          },
          "metricsStrategy": {
            "type": "string",
            "description": "default value is NONE",
            "enum": [
              "NONE",
              "CONTROL_PLANE",
              "DYNAMIC_ENGINE"
            ]
          }
        }
      },
      "SearchDynamicEngineEnvironmentsRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "like filter on name"
          },
          "deId": {
            "type": "string",
            "description": "Dynamic Engine identifier"
          },
          "limit": {
            "type": "integer",
            "format": "int32"
          },
          "offset": {
            "type": "integer",
            "format": "int32"
          },
          "sortOrder": {
            "type": "string",
            "description": "sort order of fetched dynamic engine environments",
            "default": "DESC",
            "enum": [
              "ASC",
              "DESC"
            ],
            "example": "DESC"
          },
          "sortBy": {
            "type": "string",
            "description": "attribute dynamic engine environments are sorted by, sorted by creation time by default",
            "enum": [
              "NAME",
              "STATUS"
            ],
            "example": "\"status\""
          },
          "status": {
            "type": "string",
            "description": "Environment Dynamic Engine Connection Status",
            "enum": [
              "NOT_ASSIGNED",
              "SET_UP_REQUIRED",
              "READY",
              "NOT_READY"
            ]
          }
        }
      },
      "UpdateDynamicEngineEnvironmentRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "logStrategy": {
            "type": "string",
            "enum": [
              "NONE",
              "CONTROL_PLANE",
              "DYNAMIC_ENGINE"
            ]
          },
          "metricsStrategy": {
            "type": "string",
            "enum": [
              "NONE",
              "CONTROL_PLANE",
              "DYNAMIC_ENGINE"
            ]
          }
        }
      },
      "DEEnvironmentPage": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DEEnvironment"
            }
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          }
        }
      }
    }
  },
