    "/orchestration/dynamic-engine-environments/{environmentId}/connection": {
      "post": {
        "summary": "Create an assignment between this Environment and a Dynamic Engine",
        "description": "Pre-requisites : \n* Environment should not already be assigned to any Dynamic Engine\n* Dynamic Engine should already be fully connected to TMC\n* User should be entitled Engine Manage permission, provided through Infrastructure Administrator Role or your custom one. ",
        "parameters": [
          {
            "name": "dynamicEngineId",
            "in": "query",
            "required": true,
            "description": "Identifier of the Dynamic Engine cluster to assign to",
            "schema": {
              "type": "string",
              "description": "Identifier of the Dynamic Engine cluster to assign to"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Environment connection to the data plane is processing",
            "headers": {
              "Location": {
                "description": "Connection link unique id",
                "required": true,
                "schema": {
                  "type": "string",
                  "description": "Connection link unique id"
                }
              }
            }
          },
          "204": {
            "description": "Environment is already connected to this data plane",
            "headers": {
              "Location": {
                "description": "Connection link unique id",
                "required": true,
                "schema": {
                  "type": "string",
                  "description": "Connection link unique id"
                }
              }
            }
          },
          "400": {
            "description": "Status 400",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Status 401",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Status 403",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "The environment is already connected to some different DataPlane",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Status 500",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "The data plane is not ready for connection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "5XX": {
            "description": "Namespace allocation is not possible / timeout on comm with DP / etc",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
