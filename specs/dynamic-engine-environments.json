{
  "openapi": "3.0.1",
  "info": {
    "title": "Dynamic Engine Environments",
    "description": "Manage and assign your Environments to Dynamic Engines. ",
    "contact": {},
    "version": "2021-03"
  },
  "paths": {
    "/orchestration/dynamic-engine-environments": {
      "summary": "Dynamic Engine Environments",
      "description": "While providing all capacity related to Environments (see description), Dynamic Engine Environment also brings Dynamic Engine processing for all tasks or plans defined within. \n\nThis **processing capacity** is provided through the assignment of your Environment to one (and one only) available Dynamic Engine. Doing so, you dont need to provide any Engine definition on the task level.  \n\nThis processing capacity is **exclusive**, meaning all tasks or plans defined in your Environment will target this Dynamic Engine for execution. \n\nThe **status** of your Dynamic Engine Environment reflects both this assignment state and the **processing readiness state**. ",
      "post": {
        "summary": "Create new Dynamic Engine Environment",
        "description": "A Dynamic Engine Environment is an Environment that can be assigned to one Dynamic Engine. \n\nWhile keeping all existing capability available on Environments, it also brings Dynamic Engine targeted executions :  once connected, all executions of any task or plan defined within this Environment will occur on the assigned Dynamic Engine. Please consult Connection sub-resource to learn more about Dynamic Engine connection facility.\n\nPre-requisites : \n* User should be entitled Environments Manage permission, provided through Environment Administrator Role or your custom one. \n* environment name must be unique (leading or trailing spaces are removed)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDynamicEngineEnvironmentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Status 201",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DEEnvironment"
                }
              }
            }
          },
          "400": {
            "description": "Incorrect request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Status 401",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Not authorized to create the environment",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Environment name should be unique",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Status 500",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
